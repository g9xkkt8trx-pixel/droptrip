# ローカル開発用です。このファイルをコピーして .env を作成してください。
# 本番ドメイン確定後にProductionだけへ設定する公開URLです。https://example.com の形式で指定します。
# 未設定ならcanonical/OGPの絶対URLは出力しません。Previewには設定しません。
VITE_PUBLIC_SITE_URL=

# localhostでServerless Functionを使えない場合だけ使用する開発専用キーです。
# VITE_接頭辞の値はブラウザへ公開されるため、Production/Previewへ設定しません。
VITE_GOOGLE_MAPS_API_KEY=
# localhostでServerless Functionを使えない場合だけ使用する開発専用キーです。
VITE_OPENAI_API_KEY=
VITE_OPENAI_PLAN_MODEL=gpt-4.1-mini

# Vercelなどのサーバー環境変数に設定します。ブラウザには公開されません。
# Productionと、APIを確認するPreviewに設定します。
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=
OPENAI_PLAN_MODEL=gpt-4.1-mini
